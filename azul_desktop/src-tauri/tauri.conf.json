{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AzulClaw",
  "mainBinaryName": "AzulClaw",
  "version": "1.0.0",
  "identifier": "com.azulclaw.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AzulClaw",
        "width": 1480,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "AzulClaw",
    "homepage": "https://github.com/Javierif/AzulClaw",
    "shortDescription": "Azure-first desktop shell for AzulClaw.",
    "longDescription": "AzulClaw is an Azure-first desktop companion that bundles the desktop shell, backend runtime, and first-run Hatching setup into a single Windows installation.",
    "targets": [
      "nsis"
    ],
    "resources": {
      "../resources/backend": "backend"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "AzulClaw",
        "headerImage": "nsis/assets/installer-header.bmp",
        "sidebarImage": "nsis/assets/installer-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/desktop-shortcut.nsh"
      }
    },
    "icon": [
      "icons/icon.ico"
    ]
  }
}
