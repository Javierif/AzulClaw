{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azulclaw.dev/schemas/azul.skill.schema.json",
  "title": "AzulClaw Skill Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "publisher",
    "description",
    "kind",
    "runtime",
    "compatibility",
    "permissions",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]{2,127}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "publisher": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "local_mcp",
        "remote_agent",
        "knowledge",
        "workflow",
        "channel_connector"
      ]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["none", "mcp", "remote_agent"]
        },
        "transport": {
          "type": "string",
          "enum": ["stdio", "http"]
        },
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "endpoint": {
          "type": "string",
          "format": "uri"
        },
        "auth": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["azulclaw_min_version"],
      "properties": {
        "azulclaw_min_version": {
          "type": "string"
        }
      }
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "icon_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "banner": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "variant": {
              "type": "string",
              "enum": ["default", "desktop", "gemini", "telegram", "blueprint", "agent", "channel"]
            },
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 48
            },
            "image": {
              "type": "string"
            },
            "accent": {
              "type": "string",
              "pattern": "^#[0-9a-fA-F]{6}$"
            }
          }
        }
      }
    },
    "config_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "required": { "type": "boolean", "default": true }
        }
      },
      "default": []
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filesystem": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["scope", "access", "purpose"],
            "properties": {
              "scope": {
                "type": "string",
                "enum": ["none", "workspace", "user_selected_folder"]
              },
              "access": {
                "type": "string",
                "enum": ["none", "read", "read_write"]
              },
              "purpose": { "type": "string" }
            }
          },
          "default": []
        },
        "process": {
          "type": "boolean",
          "default": false
        },
        "network": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "memory": {
          "type": "string",
          "enum": ["none", "read", "write", "read_write"],
          "default": "none"
        },
        "channels": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "sensitive_actions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "prompt": { "type": "string" }
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "protocol_version"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["built_in_template", "isolated_process"]
        },
        "protocol_version": {
          "type": "string",
          "minLength": 1
        },
        "entrypoint": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "command": { "type": "string", "minLength": 1 },
            "args": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          }
        },
        "tools": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 },
          "default": {}
        },
        "tool_policies": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "requires_approval": {
                "type": "boolean",
                "default": false
              },
              "sensitive_action": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "default": {}
        },
        "input_defaults": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "sensitive_actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "capability_prompt": {
          "type": "string"
        },
        "schemas": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 },
          "default": {}
        },
        "checkpoint_policy": {
          "type": "string",
          "enum": ["none", "optional", "required"],
          "default": "optional"
        }
      }
    },
    "activation": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
