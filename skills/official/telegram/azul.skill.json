{
  "schema_version": "1.0",
  "id": "dev.azulclaw.telegram",
  "name": "Telegram",
  "version": "0.1.0",
  "publisher": "AzulClaw",
  "description": "Connect AzulClaw to Telegram through the Azure Bot relay pattern.",
  "kind": "channel_connector",
  "runtime": {
    "kind": "none"
  },
  "compatibility": {
    "azulclaw_min_version": "0.1.0"
  },
  "categories": ["channels"],
  "tags": ["telegram", "bot-framework", "azure-functions", "service-bus"],
  "presentation": {
    "icon_text": "TG",
    "banner": {
      "variant": "telegram",
      "title": "Telegram",
      "accent": "#38bdf8"
    }
  },
  "config_schema": {
    "type": "object",
    "required": ["botToken"],
    "properties": {
      "botToken": {
        "type": "string",
        "title": "Telegram bot token",
        "format": "password"
      },
      "allowedUserIds": {
        "type": "string",
        "title": "Allowed Telegram user IDs"
      },
      "allowedChatIds": {
        "type": "string",
        "title": "Allowed Telegram chat IDs"
      }
    },
    "additionalProperties": false
  },
  "secrets": [
    {
      "name": "TELEGRAM_BOT_TOKEN",
      "config_field": "botToken",
      "title": "Telegram bot token",
      "description": "Bot token generated by BotFather.",
      "required": true
    }
  ],
  "permissions": {
    "filesystem": [],
    "process": false,
    "network": ["api.telegram.org"],
    "memory": "none",
    "channels": ["telegram"],
    "sensitive_actions": ["send_external_message"]
  },
  "capabilities": [
    {
      "id": "telegram.channel",
      "description": "Receive and send Telegram messages through the Azure relay."
    }
  ],
  "activation": {
    "restart_required": true,
    "requires_azure_relay": true,
    "relay_function_path": "src/relay_function"
  }
}
