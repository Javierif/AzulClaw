# Copy to .env.local and fill in real values (never commit .env.local).
# load_runtime_config() only reads .env.local from this directory.

# --- Azure OpenAI (shared fallback when FAST/SLOW are unset) ---
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

# Main chat deployment (slow lane default if AZURE_OPENAI_SLOW_DEPLOYMENT is empty)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Fast lane (heartbeats, low-latency tasks, background preference extraction) ---
# Recommended for fire-and-forget JSON extraction: a small / fast model on Azure.
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-5.4-nano
# Optional: separate endpoint or key for the fast resource (else AZURE_OPENAI_* is used)
# AZURE_OPENAI_FAST_ENDPOINT=
# AZURE_OPENAI_FAST_API_KEY=
# AZURE_OPENAI_FAST_API_VERSION=

# --- Slow lane (main assistant turns; optional overrides) ---
# AZURE_OPENAI_SLOW_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_SLOW_ENDPOINT=
# AZURE_OPENAI_SLOW_API_KEY=

# --- Embeddings (vector memory; must match AZUL_EMBEDDING_DIM on the deployment) ---
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# --- Workspace sandbox (MCP file tools + hatching default) ---
# If unset, defaults to ~/Documents/dev/AzulWorkspace on all platforms.
# AZUL_WORKSPACE_ROOT=/Users/you/Documents/dev/AzulWorkspace

# --- Persistent memory (SQLite) ---
# If unset, the DB is <workspace_root>/.azul/azul_memory.db (workspace from Hatching).
# Set this to override (absolute path recommended).
# AZUL_MEMORY_DB_PATH=/Users/you/Documents/dev/AzulClawData/azul_memory.db
AZUL_EMBEDDING_DIM=3072
# VECTOR_MEMORY_ENABLED=true
# AZUL_HYBRID_VECTOR_WEIGHT=0.7
# AZUL_HYBRID_TEXT_WEIGHT=0.3
# AZUL_PREFERENCE_EXTRACTION_ENABLED=true
# MEMORY_MAX_MESSAGES=50

# --- Bot Framework (production; leave empty for local emulator) ---
# MicrosoftAppId=
# MicrosoftAppPassword=
# PORT=3978
